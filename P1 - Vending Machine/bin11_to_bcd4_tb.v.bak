module bin11_to_bcd4_tb;
	
	reg  [10:0] test_input
	wire [15:0] test_output
	bin11_to_bc4 uut (
		.bin(test_input),
		.bcd(test_output)
	)
	
	initial begin
		$display("Inicio");
		test_input = 10; #10;
		$display("%4d = %1d %1d %1d %1d", test_input, test_output[15:12], test_output[11:8], test_output[7:4], test_output[3:0]); 
		$finish
	end 
endmodule