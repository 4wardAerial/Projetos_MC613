module bin11_to_bcd4(
	input wire [10:0] bin,
	output reg [15:0] bcd
);
	integer i;
	
	always @(*) begin
		reg [10:0] x;
		reg [15:0] acc;
		
		x = bin;
		acc = 16'b0;
		
		for(i = 10; i >= 0; i = i - 1) begin
			if(acc[3:0] > 4)
				acc[3:0] = acc[3:0] + 3;
			if(acc[7:4] > 4)
				acc[7:4] = acc[7:4] + 3;
			if(acc[11:8] > 4)
				acc[11:8] = acc[11:8] + 3;
			if(acc[15:12] > 4)
				acc[15:12] = acc[15:12] + 3;
			
			acc = {acc[14:0], x[i]};
		end
		
		bcd = acc;
		
	end
endmodule